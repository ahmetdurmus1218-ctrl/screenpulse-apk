<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions" />
    <!-- Required on Android 11+ (API 30+) so PackageManager can resolve the
         name/icon of every app that shows up in the usage stats list, not just
         apps this app has visibility of by default. Fine for a personal/sideloaded
         app, but Play Store submissions require a declared-use justification
         for this permission. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" tools:ignore="QueryAllPackages" />

    <application
        android:name=".ScreenPulseApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".widget.ScreenPulseWidgetProvider2x2"
            android:exported="true"
            android:label="ScreenPulse 2x2">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_2x2" />
        </receiver>

        <receiver
            android:name=".widget.ScreenPulseWidgetProvider4x2"
            android:exported="true"
            android:label="ScreenPulse 4x2">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_4x2" />
        </receiver>

        <receiver
            android:name=".widget.ScreenPulseWidgetProvider4x4"
            android:exported="true"
            android:label="ScreenPulse 4x4">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_4x4" />
        </receiver>

        <receiver
            android:name=".widget.ScreenPulseWidgetProvider2x4"
            android:exported="true"
            android:label="ScreenPulse 2x4">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_2x4" />
        </receiver>

        <receiver
            android:name=".widget.ScreenPulseWidgetProvider1x4"
            android:exported="true"
            android:label="ScreenPulse 1x4">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_1x4" />
        </receiver>

    </application>

</manifest>
