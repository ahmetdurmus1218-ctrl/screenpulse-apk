<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="horizontal"
    android:padding="20dp"
    android:gravity="center_vertical">

    <!-- SOT details on the left -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SCREEN PULSE"
            android:textColor="#88FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <Spacer
            android:layout_width="match_parent"
            android:layout_height="6dp" />

        <TextView
            android:id="@+id/widget_sot_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0sa 0dk"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Şarj sonrası ekran açık süresi"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_last_charge_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Son Şarj: 12:00"
            android:textColor="#55FFFFFF"
            android:textSize="10sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Circular battery progress on the right -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.8"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="4dp">

        <ImageView
            android:id="@+id/widget_battery_circle"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="fitCenter"
            android:contentDescription="Battery indicator" />
    </LinearLayout>

</LinearLayout>
