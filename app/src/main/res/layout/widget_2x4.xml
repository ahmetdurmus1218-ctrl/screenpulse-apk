<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_widget_sun" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Son Şarjdan Beri"
            android:textColor="#99AAB8E8"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

    <TextView
        android:id="@+id/widget_sot_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3sa 18dk"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ekran Açık Süresi"
        android:textColor="#7A97FF"
        android:textSize="11sp"
        android:textStyle="bold" />

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#14FFFFFF"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="%55"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/widget_battery_icon"
            android:layout_width="20dp"
            android:layout_height="10dp"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pil Seviyesi"
        android:textColor="#66FFFFFF"
        android:textSize="10sp"
        android:layout_marginBottom="4dp" />

</LinearLayout>
